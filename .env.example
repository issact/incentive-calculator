NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
API_URL=http://localhost:5000/api/v1

# Server
PORT=5000
NODE_ENV=development

# CORS (comma-separated list, no trailing slash)
# Example: CORS_ORIGINS=http://localhost:3000,https://name.vercel.app
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# Auth (required)
JWT_SECRET=replace_with_a_strong_secret

# Email (Brevo transactional)
# 1) Verify EMAIL_FROM in Brevo (Sender settings)
# 2) Create BREVO_API_KEY in Brevo (SMTP & API)
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=verified_sender@yourdomain.com
EMAIL_FROM_NAME="Incentive System"

# Set to true to test without delivering emails (Brevo sandbox "drop")
BREVO_SANDBOX=false

# Used to generate links inside notification emails (optional)
APP_BASE_URL=http://localhost:3000

# Prisma seed (optional; used by `npm run db:seed`)
ADMIN_NAME="Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"
